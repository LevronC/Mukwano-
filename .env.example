# Copy to packages/api/.env and fill in real values
DATABASE_URL=postgresql://mukwano:mukwano@localhost:5432/mukwano
JWT_SECRET=change-me-256-bits-minimum
REFRESH_TOKEN_SECRET=change-me-different-from-jwt-secret
DEMO_MODE=true
PORT=4000
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
# Production (Vercel): add RESEND_API_KEY, RESEND_FROM, and APP_URL on the *API* project (mukwano-api),
# not only the web app — the browser never sees the key. GET /api/v1/config returns emailConfigured.
# Optional: Resend API key for verification and password-reset emails (omit in dev to log links only)
RESEND_API_KEY=
RESEND_FROM=Mukwano <onboarding@resend.dev>
