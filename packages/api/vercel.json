{
  "version": 2,
  "buildCommand": "npm run deploy:triggers && npm run vercel:migrate && npm run prisma:generate",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "includeFiles": "src/**,prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
