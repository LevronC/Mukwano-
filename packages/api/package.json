{
  "name": "@mukwano/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "postinstall": "node -e \"if(process.env.DATABASE_URL){require('child_process').execSync('prisma generate',{stdio:'inherit'})}\"",
    "prebuild": "npm run prisma:generate",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:all": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:unit:coverage": "vitest run --coverage test/unit",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "deploy:triggers": "node scripts/deploy-triggers.mjs",
    "vercel:migrate": "node scripts/vercel-migrate.mjs"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@fastify/cors": "11.2.0",
    "@fastify/env": "6.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "10.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "7.6.0",
    "@sentry/node": "^9.47.1",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "3.0.3",
    "dotenv": "^16.6.1",
    "fastify": "5.8.4",
    "fastify-plugin": "5.1.0",
    "node-cron": "^4.2.1",
    "otplib": "^13.4.0",
    "pg": "^8.14.1",
    "prisma": "7.6.0",
    "qrcode": "^1.5.4",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.3",
    "stripe": "^22.1.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/node": "22.13.10",
    "@types/pg": "^8.11.11",
    "@types/uuid": "11.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
