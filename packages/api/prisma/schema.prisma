generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String             @id @default(uuid()) @db.Uuid
  email         String             @unique
  passwordHash  String
  displayName   String
  country       String?
  residenceCountry String?
  /** U.S. state/territory name when `residenceCountry` is United States. */
  residenceRegion  String?
  sector        String?
  avatarUrl     String?
  /** Legacy flag; kept in sync with `platformRole` for JWT and older clients. */
  isGlobalAdmin Boolean            @default(false)
  /** Platform-level role: USER or GLOBAL_ADMIN. Circle CREATOR/ADMIN use `CircleMembership.role`. */
  platformRole  String             @default("USER")
  emailVerified Boolean            @default(false)
  lastVerificationEmailSent DateTime?
  deactivatedAt DateTime?
  totpSecret    String?
  totpEnabled   Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  emailTokens   EmailToken[]
  memberships   CircleMembership[]
  circles       Circle[]           @relation("CircleCreatedBy")
  refreshTokens RefreshToken[]
  contributions Contribution[]
  verifiedContributions Contribution[] @relation("ContributionVerifiedBy")
  ledgerEntries LedgerEntry[]
  proposals      Proposal[]      @relation("ProposalCreatedBy")
  votes          Vote[]
  projectUpdates ProjectUpdate[]
  notifications  Notification[]
  auditLogsAsSubject AuditLog[]   @relation("AuditLogSubjectUser")
  supportFlagsReported SupportFlag[] @relation("SupportFlagReporter")
  supportFlagsAbout    SupportFlag[] @relation("SupportFlagSubject")

  @@index([platformRole], map: "idx_users_platform_role")
  @@index([createdAt], map: "idx_users_created_at")
  @@map("users")
}

model RefreshToken {
  id        String    @id @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  family    String    @db.Uuid
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type], map: "idx_email_tokens_user_type")
  @@map("email_tokens")
}

model IdempotencyKey {
  id             String   @id @default(uuid()) @db.Uuid
  key            String
  userId         String   @db.Uuid
  endpoint       String
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())

  @@unique([key, userId])
  @@index([createdAt], map: "idx_idempotency_keys_created_at")
  @@map("idempotency_keys")
}

model LoginAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  ipAddress String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt(sort: Desc)], map: "idx_login_attempts_email")
  @@index([createdAt], map: "idx_login_attempts_created_at")
  @@map("login_attempts")
}

model Circle {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  description      String?
  /** Human-readable country name (same values as user onboarding). */
  country          String?
  /** Sector label (same values as `ONBOARDING_SECTORS` on the web). */
  sector           String?
  coverImageUrl    String?
  goalAmount       Decimal            @db.Decimal(18, 2)
  currency         String             @default("USD")
  status           String             @default("active")
  createdBy        String             @db.Uuid
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  memberships      CircleMembership[]
  creator          User               @relation("CircleCreatedBy", fields: [createdBy], references: [id])
  governanceConfig GovernanceConfig?
  contributions    Contribution[]
  ledgerEntries    LedgerEntry[]
  proposals        Proposal[]
  projects         Project[]

  @@map("circles")
}

model GovernanceConfig {
  id                   String   @id @default(uuid()) @db.Uuid
  circleId             String   @unique @db.Uuid
  minContribution      Decimal  @default(0) @db.Decimal(18, 2)
  votingModel          String   @default("one_member_one_vote")
  quorumPercent        Int      @default(51)
  approvalPercent      Int      @default(51)
  proposalDurationDays Int      @default(7)
  whoCanPropose        String   @default("contributor")
  requireProof         Boolean  @default(true)
  createdAt            DateTime @default(now())
  circle               Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@map("governance_configs")
}

model CircleMembership {
  id       String   @id @default(uuid()) @db.Uuid
  circleId String   @db.Uuid
  userId   String   @db.Uuid
  role     String   @default("member")
  joinedAt DateTime @default(now())
  circle   Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([circleId], map: "idx_memberships_circle")
  @@index([userId], map: "idx_memberships_user")
  @@map("circle_memberships")
}

model Contribution {
  id              String   @id @default(uuid()) @db.Uuid
  circleId        String   @db.Uuid
  userId          String   @db.Uuid
  amount          Decimal  @db.Decimal(18, 2)
  currency        String   @default("USD")
  status          String   @default("pending")
  note            String?
  submittedAt     DateTime @default(now())
  verifiedAt      DateTime?
  verifiedBy      String?  @db.Uuid
  rejectionReason         String?
  ledgerEntryId           String?  @db.Uuid @unique
  stripeCheckoutSessionId String?  @unique
  circle          Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier        User?    @relation("ContributionVerifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)
  proofDocuments  ProofDocument[]

  @@index([circleId], map: "idx_contributions_circle")
  @@index([userId], map: "idx_contributions_user")
  @@index([status], map: "idx_contributions_status")
  @@index([status, verifiedAt], map: "idx_contributions_status_verified_at")
  @@index([status, submittedAt], map: "idx_contributions_status_submitted_at")
  @@map("contributions")
}

model ProofDocument {
  id             String   @id @default(uuid()) @db.Uuid
  contributionId String   @db.Uuid
  fileKey        String
  fileName       String
  mimeType       String?
  sizeBytes      Int?
  uploadedBy     String   @db.Uuid
  uploadedAt     DateTime @default(now())
  contribution   Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  @@map("proof_documents")
}

model LedgerEntry {
  id                      String   @id @default(uuid()) @db.Uuid
  circleId                String   @db.Uuid
  userId                  String   @db.Uuid
  amount                  Decimal  @db.Decimal(18, 2)
  runningBalance          Decimal  @db.Decimal(18, 2)
  currency                String   @default("USD")
  type                    String
  referenceContributionId String?  @db.Uuid
  metadata                Json?
  recordedAt              DateTime @default(now())
  circle                  Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([circleId, recordedAt], map: "idx_ledger_circle")
  @@index([userId], map: "idx_ledger_user")
  @@index([recordedAt], map: "idx_ledger_recorded_at")
  @@map("ledger_entries")
}

model Proposal {
  id              String   @id @default(uuid()) @db.Uuid
  circleId        String   @db.Uuid
  createdBy       String   @db.Uuid
  title           String
  description     String
  requestedAmount Decimal  @db.Decimal(18, 2)
  currency        String   @default("USD")
  status          String   @default("open")
  votingDeadline  DateTime
  quorumMet       Boolean  @default(false)
  finalYes        Int      @default(0)
  finalNo         Int      @default(0)
  finalAbstain    Int      @default(0)
  closedAt        DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  circle          Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  creator         User     @relation("ProposalCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  votes           Vote[]
  projects        Project[]

  @@index([circleId], map: "idx_proposals_circle")
  @@index([status], map: "idx_proposals_status")
  @@map("proposals")
}

model Vote {
  id         String   @id @default(uuid()) @db.Uuid
  proposalId String   @db.Uuid
  userId     String   @db.Uuid
  vote       String
  castAt     DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
  @@index([proposalId], map: "idx_votes_proposal")
  @@index([userId], map: "idx_votes_user")
  @@map("votes")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  circleId    String   @db.Uuid
  proposalId  String   @db.Uuid
  createdBy   String   @db.Uuid
  title       String
  description String
  budget      Decimal  @db.Decimal(18, 2)
  currency    String   @default("USD")
  /// Impact category for portfolio analytics (e.g. Healthcare, Education)
  sector      String?
  /// ISO 3166-1 alpha-2 country code for geographic allocation
  countryCode String?  @db.VarChar(2)
  status      String   @default("approved")
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  circle      Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Restrict)
  updates     ProjectUpdate[]

  @@index([circleId], map: "idx_projects_circle")
  @@index([status], map: "idx_projects_status")
  @@map("projects")
}

model ProjectUpdate {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  postedBy        String   @db.Uuid
  content         String
  percentComplete Int      @default(0)
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [postedBy], references: [id], onDelete: Cascade)

  @@index([projectId], map: "idx_project_updates_project")
  @@map("project_updates")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  event     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_notifications_user")
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  circleId   String?  @db.Uuid
  actorId    String?  @db.Uuid
  /** User impacted by the action (e.g. role grant), when applicable. */
  subjectUserId String? @db.Uuid
  subjectUser   User?  @relation("AuditLogSubjectUser", fields: [subjectUserId], references: [id], onDelete: SetNull)
  entityType String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([circleId, createdAt], map: "idx_audit_logs_circle_created_at")
  @@index([actorId, createdAt], map: "idx_audit_logs_actor_created_at")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([subjectUserId, createdAt], map: "idx_audit_logs_subject_created_at")
  @@map("audit_logs")
}

/** Lightweight admin triage queue; extend with assignments and SLA later. */
model SupportFlag {
  id            String   @id @default(uuid()) @db.Uuid
  reporterId    String   @db.Uuid
  subjectUserId String?  @db.Uuid
  subjectType   String   @default("user")
  reason        String
  status        String   @default("open")
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reporter      User     @relation("SupportFlagReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  subjectUser   User?    @relation("SupportFlagSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)], map: "idx_support_flags_status_created")
  @@index([subjectUserId], map: "idx_support_flags_subject")
  @@index([reporterId, createdAt(sort: Desc)], map: "idx_support_flags_reporter_created")
  @@map("support_flags")
}
